{
  "gateway": {
    "mode": "local",
    "bind": "lan"
  },
  "mcpServers": {
    "ob1": {
      "url": "http://ob1-mcp:8000?schema=agent2",
      "transport": "http"
    }
  },
  "browser": {
    "enabled": true,
    "headless": false,
    "noSandbox": true,
    "attachOnly": true,
    "defaultProfile": "remote",
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": true
    },
    "profiles": {
      "remote": {
        "cdpUrl": "http://chromium-agent2:9223",
        "color": "#FF4500"
      }
    }
  }
}