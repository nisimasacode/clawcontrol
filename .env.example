# =============================================================================
# agent-orc  —  Environment Variables
# Copy to .env and fill in your values.
# =============================================================================

# ── Timezone ─────────────────────────────────────────────────────────────────
TZ=Europe/Berlin

# ── OB1 Database (PostgreSQL + pgvector) ─────────────────────────────────────
POSTGRES_USER=ob1
POSTGRES_PASSWORD=CHANGE_ME_ob1_password
POSTGRES_DB=openbrain
POSTGRES_PORT=5432

# PostgREST
PGRST_JWT_SECRET=CHANGE_ME_super_secret_jwt_token_at_least_32_characters_long

# ── Volume base path ────────────────────────────────────────────────────────
# Unraid:   /mnt/user/appdata/agent-orc
# Linux:    ./data
# Adjust to match your host.
DATA_ROOT=/mnt/user/appdata/agent-orc

# ── Model Provider API Keys (set at least one) ──────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# ── OpenClaw Gateway Tokens (one per instance) ──────────────────────────────
# Generate with: openssl rand -hex 32
ORCHESTRATOR_GATEWAY_TOKEN=
AGENT1_GATEWAY_TOKEN=
AGENT2_GATEWAY_TOKEN=

# ── Port Mappings ────────────────────────────────────────────────────────────
# OpenClaw gateway ports (host:container)
ORCHESTRATOR_GATEWAY_PORT=18789
AGENT1_GATEWAY_PORT=18791
AGENT2_GATEWAY_PORT=18793

# OpenClaw bridge ports
ORCHESTRATOR_BRIDGE_PORT=18790
AGENT1_BRIDGE_PORT=18792
AGENT2_BRIDGE_PORT=18794

# Chromium HTTPS UI ports
ORCHESTRATOR_CHROMIUM_UI_PORT=3001
AGENT1_CHROMIUM_UI_PORT=3002
AGENT2_CHROMIUM_UI_PORT=3003

# Chromium CDP ports (exposed via socat relay)
ORCHESTRATOR_CHROMIUM_CDP_PORT=9223
AGENT1_CHROMIUM_CDP_PORT=9224
AGENT2_CHROMIUM_CDP_PORT=9225

# OB1 PostgREST port
OB1_REST_PORT=3100

# OB1 PostgreSQL exposed port (for external tools like pgAdmin)
OB1_DB_PORT=5433

# ── Channel Tokens (optional, shared across agents or set per-agent) ────────
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
